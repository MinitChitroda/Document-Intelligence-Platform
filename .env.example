# Database Configuration (Postgres / RDS)
DB_HOST=your-rds-or-local-db-host
DB_PORT=5432
DB_NAME=document_platform
DB_USER=postgres
DB_PASSWORD=your-secure-password-here

# AWS Configuration (S3 Storage)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-document-platform-bucket

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Vector Database (Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-qdrant-api-key

# LLM Provider (Groq API)
GROQ_API_KEY=gsk_your_groq_api_key_placeholder
